# DiffSafeSAE — env template. Copy to .env and fill in tokens; .env is gitignored.

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
WANDB_API_KEY=wandb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=dsi-v1
WANDB_ENTITY=

DATA_ROOT=/workspace/datasets
MODEL_ROOT=/workspace/.cache/huggingface
SAE_ROOT=/workspace/checkpoints/saes
CHECKPOINT_ROOT=/workspace/checkpoints
CACHE_ROOT=/workspace/.cache
OUTPUT_ROOT=/workspace/swadesh/gen_ai_project_diffusion_interp/outputs

HF_HOME=/workspace/.cache/huggingface
HF_HUB_ENABLE_HF_TRANSFER=1
# Do NOT set TRANSFORMERS_CACHE — it is deprecated and shadows HF_HOME.
# dsi.config strips it at import to be safe.
